  "universal_guidelines": [
    "Use 'slate-950' as the absolute background color for the page.",
    "NEVER use pure black (#000000) for backgrounds; use slate-950 or slate-900.",
    "All cards must use glassmorphism: 'bg-slate-900/60 backdrop-blur-xl border border-white/10'.",
    "Text hierarchy: Headings = text-white, Body = text-slate-400, Muted = text-slate-600.",
    "Interactive elements must have a hover state: 'hover:bg-white/5' or 'hover:border-purple-500/50'.",
    "Use 'data-testid' for all interactive elements.",
    "Maintain the 'Manrope' font family.",
    "Ensure all gradients are subtle and do not overpower the content."
