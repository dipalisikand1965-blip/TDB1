        "alt": "Veterinary Care",
        "category": "service"
      },
      "shop_toys": {
        "url": "https://images.unsplash.com/photo-1756073721812-0611ba3a2431?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDQ2Mzl8MHwxfHNlYXJjaHwzfHxoYXBweSUyMGRvZyUyMHBvcnRyYWl0fGVufDB8fHx8MTc3MDExMDU0Nnww&ixlib=rb-4.1.0&q=85",
        "alt": "Dog Toys",
