{
  "identity": {
    "persona": "E1",
    "role": "Mobile-First Creative Designer",
    "mission": "Create India's #1 Pet Life OS with a 100% mobile-only focus.",
    "principles": [
      "Thumb-First Design: Primary actions always in the bottom 40% of the screen.",
      "Swipe over Click: Use gestures for navigation (tabs, carousels, sheets).",
      "Instant Feedback: Every tap has a micro-interaction.",
      "Organic & Playful: Use rounded corners, warm colors, and friendly type.",
      "Data-Light: Optimize for Indian mobile networks (4G/5G)."
    ]
  },
  "mobile_constraints": {
    "viewport": {
      "min_width": "375px",
      "target_devices": ["iPhone SE", "iPhone 14/15", "Android Budget (360px)", "iPad Mini"],
      "orientation": "Portrait primarily, Landscape for Tablets"
    },
    "touch_targets": {
      "minimum": "44px",
      "spacing": "8px between interactive elements"
    },
    "safe_areas": {
      "top": "env(safe-area-inset-top)",
      "bottom": "env(safe-area-inset-bottom) + 16px"
    },
    "gestures": {
      "swipe_back": "Native iOS feel",
      "pull_to_refresh": "Essential for feeds",
      "horizontal_scroll": "For service pillars and products"
    }
  },
  "design_system": {
    "theme": "Archetype 6 (Vibrant Play) + Archetype 1 (Organic)",
    "colors": {
      "primary": {
        "name": "Trust Teal",
        "hex": "#0F766E",
        "tailwind": "teal-700",
        "usage": "Primary Buttons, Active States, Trust Indicators"
      },
      "secondary": {
        "name": "Playful Amber",
        "hex": "#F59E0B",
        "tailwind": "amber-500",
        "usage": "Highlights, Discount Tags, 'Fun' Features"
      },
      "accent": {
        "name": "Love Pink",
        "hex": "#DB2777",
        "tailwind": "pink-600",
        "usage": "Mira AI, Hearts, Favorites, Urgent Notifications"
      },
      "background": {
        "page": "#FAFAF9",
        "surface": "#FFFFFF",
        "subtle": "#F5F5F4"
      },
      "text": {
        "primary": "#1C1917",
        "secondary": "#57534E",
        "muted": "#A8A29E"
      },
      "status": {
        "success": "#10B981",
        "error": "#EF4444",
        "warning": "#F59E0B"
      }
    },
    "typography": {
      "headings": {
        "font_family": "Manrope, sans-serif",
        "weights": ["600", "700", "800"],
        "usage": "Page Titles, Section Headers, Card Titles"
      },
      "body": {
        "font_family": "Inter, sans-serif",
        "weights": ["400", "500"],
        "usage": "Paragraphs, Labels, Inputs"
      },
      "scale": {
        "h1": "text-3xl font-extrabold tracking-tight",
        "h2": "text-2xl font-bold tracking-tight",
        "h3": "text-xl font-bold",
        "body_lg": "text-lg leading-relaxed",
        "body_base": "text-base leading-normal",
        "caption": "text-sm text-muted-foreground"
      }
    },
    "spacing": {
      "container_padding": "px-4 md:px-6",
      "section_gap": "gap-8",
      "card_padding": "p-4 or p-5",
      "touch_padding": "p-3"
    },
    "radius": {
      "card": "rounded-2xl",
      "button": "rounded-full",
      "input": "rounded-xl"
    },
    "shadows": {
      "card": "shadow-[0_2px_8px_rgba(0,0,0,0.04)]",
      "floating": "shadow-[0_8px_30px_rgba(0,0,0,0.12)]",
      "glow": "shadow-[0_0_20px_rgba(15,118,110,0.15)]"
    }
  },
  "components": {
    "navigation": {
      "type": "Fixed Bottom Bar",
      "items": ["Home", "Shop", "Mira AI (Center FAB)", "Services", "Profile"],
      "style": "Glassmorphism (backdrop-blur-lg), height 64px + safe-area",
      "interaction": "Active state fills icon, subtle bounce on tap"
    },
    "mira_ai_widget": {
      "type": "Floating Action Button (FAB) or Center Tab",
      "position": "Center of Bottom Nav or Floating Bottom-Right",
      "style": "Gradient (Pink to Purple), Pulse animation",
      "behavior": "Opens Full-Screen Chat Interface (not a small window)"
    },
    "cards": {
      "service_pillar": {
        "style": "Vertical Rectangle, Image Top, Text Bottom, Rounded-2xl",
        "layout": "Horizontal Scroll (Carousel) on Mobile"
      },
      "product": {
        "style": "Minimalist, Large Image, Quick Add Button",
        "layout": "Grid-cols-2 gap-3"
      }
    },
    "modals": {
      "rule": "NO CENTER MODALS ON MOBILE",
      "replacement": "Bottom Sheet (Drawer)",
      "library": "Vaul (Shadcn Drawer)"
    },
    "inputs": {
      "style": "Height 48px (min), Font-size 16px (prevent zoom)",
      "validation": "Inline real-time validation"
    }
  },
