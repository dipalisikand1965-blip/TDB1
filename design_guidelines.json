    "icons": {
      "library": "Lucide React",
      "style": "Stroke width 2px, Rounded caps"
    }
  },
  "instructions_to_main_agent": [
    "1. MOBILE FIRST: Do not design for desktop. Assume the user is on a 375px-430px screen.",
    "2. NAVIGATION: Implement the 'Fixed Bottom Bar' immediately. It is the anchor of the app.",
    "3. MIRA AI: Make the AI assistant prominent. It's a key differentiator.",
    "4. SCROLLING: Use 'Lenis' for smooth scrolling if possible, but ensure native touch feel is preserved.",
    "5. IMAGES: Use the provided Unsplash/Pexels URLs. Do not use placeholders.",
    "6. SHADCN: Use 'Drawer' for all sub-views. Use 'Carousel' for service pillars.",
    "7. TESTING: Add 'data-testid' to all interactive elements."
  ],
  "universal_guidelines": {
    "avoid": ["Generic gradients", "Center-aligned text blocks", "Small clickable areas"],
    "embrace": ["Asymmetry", "Texture (noise/grain)", "Oversized typography for headings"],
    "css_rules": [
      "No 'text-align: center' on container",
      "No 'transition: all'",
      "Use 'backdrop-filter' for glass effects"
    ]
  }
}