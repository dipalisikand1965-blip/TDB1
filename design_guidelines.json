{
  "design_system": {
    "identity": {
      "name": "Pet Life OS",
      "tone": "Playful, Trustworthy, Premium, Organized",
      "archetype": "Vibrant Play + Organic & Earthy",
      "core_values": ["Fusion over Imitation", "Emotion First", "Content is King"]
    },
    "typography": {
      "font_family": {
        "heading": "Manrope, sans-serif",
        "body": "Inter, sans-serif",
        "special": "Syne, sans-serif"
      },
      "scale": {
        "h1": "text-4xl md:text-5xl font-bold tracking-tight",
        "h2": "text-3xl md:text-4xl font-bold tracking-tight",
        "h3": "text-2xl md:text-3xl font-semibold",
        "body_lg": "text-lg leading-relaxed",
        "body_base": "text-base leading-relaxed text-muted-foreground",
        "caption": "text-sm font-medium tracking-wide uppercase text-muted-foreground"
      }
    },
    "colors": {
      "palette": {
        "primary": {
          "DEFAULT": "#8B5CF6",
          "foreground": "#FFFFFF",
          "gradient_start": "#8B5CF6",
          "gradient_end": "#EC4899"
        },
        "secondary": {
          "DEFAULT": "#0D9488",
          "foreground": "#FFFFFF"
        },
        "accent": {
          "DEFAULT": "#F59E0B",
          "foreground": "#FFFFFF"
        },
        "background": {
          "DEFAULT": "#FAFAF9",
          "paper": "#FFFFFF"
        },
        "text": {
          "primary": "#1C1917",
          "secondary": "#57534E",
          "muted": "#A8A29E"
        }
      },
      "gradients": {
        "soul_score": "linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%)",
        "gamification": "linear-gradient(135deg, #FDE68A 0%, #FDBA74 50%, #FDA4AF 100%)",
        "glass": "rgba(255, 255, 255, 0.7)"
      }
    },
    "spacing": {
      "container_padding": "p-4 md:p-8 lg:p-12",
      "section_gap": "gap-8 md:gap-12",
      "card_padding": "p-6 md:p-8"
    },
    "visual_enhancers": {
      "radius": "rounded-2xl md:rounded-3xl",
      "shadows": {
        "card": "0 4px 20px -2px rgba(0, 0, 0, 0.05)",
        "float": "0 20px 40px -4px rgba(0, 0, 0, 0.1)",
        "glow": "0 0 40px rgba(139, 92, 246, 0.15)"
      },
      "glassmorphism": "backdrop-blur-xl bg-white/70 border border-white/20 shadow-sm"
    }
  },
  "layout_strategy": {
    "type": "Bento Grid",
    "mobile": {
      "columns": "grid-cols-1",
      "navigation": "Fixed Bottom Bar (Glassmorphic)",
      "padding": "px-4 pb-24 pt-4"
    },
    "desktop": {
      "columns": "grid-cols-12",
      "navigation": "Sidebar (Left, Fixed, w-64)",
      "padding": "p-8 pl-72"
    },
    "grid_areas": {
      "hero": "col-span-full md:col-span-8 row-span-2",
      "stats": "col-span-1 md:col-span-4 row-span-1",
      "list": "col-span-full md:col-span-4 row-span-2"
    }
  },
  "components": {
    "SoulScoreRing": {
      "description": "Animated circular progress bar with pet portrait in center. Uses SVG stroke-dasharray for animation.",
      "props": {
        "score": "number (0-100)",
        "petImage": "string (url)",
        "size": "number (px)"
      },
      "animation": "Rotate on load, pulse on hover"
    },
    "GamificationBanner": {
      "description": "Hero card showing current level/journey. Gradient background with 3D assets.",
      "style": "bg-gradient-to-r from-violet-500 to-fuchsia-500 text-white rounded-3xl overflow-hidden relative"
    },
    "QuickBoostCard": {
      "description": "Interactive card asking daily questions to boost score.",
      "style": "bg-white border border-orange-100 shadow-sm hover:shadow-md transition-all"
    },
    "PetSelector": {
      "description": "Horizontal scroll list of pet avatars. Active state has ring.",
      "mobile_behavior": "Horizontal scroll with snap",
      "desktop_behavior": "Grid or Vertical List in Sidebar"
    }
  },
  "assets": {
    "images": {
      "pets": [
        {
          "name": "Golden Retriever",
          "url": "https://images.unsplash.com/photo-1609348490161-a879e4327ae9?crop=entropy&cs=srgb&fm=jpg&q=85",
          "category": "Pet Portrait"
        },
        {
          "name": "French Bulldog",
          "url": "https://images.unsplash.com/photo-1618901977251-d57dd765d2e1?crop=entropy&cs=srgb&fm=jpg&q=85",
          "category": "Pet Portrait"
        },
        {
          "name": "Cavalier Spaniel",
          "url": "https://images.unsplash.com/photo-1613210609371-455e3aa5fb8c?crop=entropy&cs=srgb&fm=jpg&q=85",
          "category": "Pet Portrait"
        }
      ],
      "gamification": [
        {
          "name": "Trophy Icon",
          "url": "https://images.pexels.com/photos/8342007/pexels-photo-8342007.jpeg",
          "category": "Reward"
        },
        {
          "name": "Gift Box",
          "url": "https://images.unsplash.com/photo-1700045530510-6e03007a8f48?crop=entropy&cs=srgb&fm=jpg&q=85",
          "category": "Reward"
        }
      ]
    },
    "icons": {
      "library": "lucide-react",
      "preferred": ["Heart", "Trophy", "Activity", "Calendar", "Settings", "Home", "ShoppingBag", "FileText"]
    }
  },
  "instructions_to_main_agent": [
    "1. Refine the 'Member Dashboard' page to use a responsive Bento Grid layout.",
    "2. Implement the 'Soul Score' as a central hero element with the circular progress animation.",
    "3. Ensure the Mobile Bottom Nav is preserved but styled with the new 'Glassmorphism' rules.",
    "4. Create a 'Sidebar' component for Desktop view that replaces the Bottom Nav.",
    "5. Use the provided image URLs for the pet avatars and gamification elements.",
    "6. Apply the 'Manrope' font to all headings and 'Inter' to body text.",
    "7. Use 'framer-motion' for entrance animations (staggered fade-ins for grid items).",
    "8. Ensure all interactive elements have 'data-testid' attributes.",
    "9. DO NOT use generic linear gradients for backgrounds; use the specified 'Warm Stone' (#FAFAF9) for the page background.",
    "10. Make the 'Quick Score Boost' interactive (e.g., click to answer/expand)."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Avoid 'AI slop' aesthetics (generic centered layouts, default blue/gray).",
    "Use 2-3x more spacing than typical (p-6, p-8, gap-8).",
    "Every interaction needs micro-animations (hover lift, scale down on click).",
    "Use 'sonner' for toasts.",
    "Never use transparent backgrounds for overlays without blur.",
    "Respect 'prefers-reduced-motion'."
  ]
}