{
  "identity": {
    "persona": "E1: The Anti-AI Designer",
    "principles": [
      "Fusion over Imitation",
      "Emotion First",
      "Content is King",
      "Zoom in",
      "Negative Space",
      "Contrast"
    ],
    "anti_patterns": [
      "Generic Bootstrap/Tailwind look",
      "Center-everything layouts",
      "Gradient overload",
      "Inter font for headings"
    ]
  },
  "context": {
    "pillar": "Fit",
    "app_type": "SaaS / Pet Lifestyle Platform",
    "target_audience": "Premium pet parents in India",
    "emotional_tone": "Vitality, Precision, Trust, Scientific Warmth"
  },
  "design_system": {
    "typography": {
      "headings": {
        "font_family": "Syne, sans-serif",
        "weights": ["700", "800"],
        "usage": "Hero titles, Section headers",
        "letter_spacing": "tracking-tight",
        "import_url": "https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&display=swap"
      },
      "body": {
        "font_family": "Manrope, sans-serif",
        "weights": ["400", "500", "600"],
        "usage": "Paragraphs, UI elements, Data",
        "import_url": "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap"
      },
      "accent": {
        "font_family": "JetBrains Mono, monospace",
        "usage": "Data points, Price tags, Technical labels"
      }
    },
    "colors": {
      "palette": {
        "primary": {
          "main": "#0F766E",
          "light": "#14B8A6",
          "dark": "#115E59",
          "description": "Deep Teal/Emerald for authority and health"
        },
        "accent": {
          "main": "#84CC16",
          "hover": "#65A30D",
          "text": "#1A2E05",
          "description": "Electric Lime for high-energy actions (Book, Buy)"
        },
        "neutral": {
          "bg": "#F0FDF4",
          "surface": "#FFFFFF",
          "text_primary": "#132A13",
          "text_secondary": "#3F6212",
          "border": "#E2E8F0"
        }
      },
      "gradients": {
        "hero": "bg-gradient-to-br from-teal-900 via-emerald-800 to-teal-950",
        "card_hover": "bg-gradient-to-br from-white to-emerald-50"
      }
    },
    "spacing": {
      "container_padding": "px-6 md:px-12 lg:px-24",
      "section_gap": "py-20 md:py-32",
      "grid_gap": "gap-8 md:gap-12"
    },
    "visual_enhancers": {
      "glassmorphism": "backdrop-blur-xl bg-white/70 border border-white/20 shadow-xl",
      "shadows": "shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)]",
      "borders": "border border-emerald-100",
      "radius": "rounded-2xl md:rounded-3xl"
    }
  },
  "layout_strategy": {
    "hero_section": {
      "type": "Asymmetric Split",
      "structure": "Left: Typography + CTA (60%) | Right: Cutout Image (40%)",
      "elements": [
        "Massive 'Syne' Headline (text-6xl+)",
        "Floating 3D-style elements (badges, stats)",
        "Primary CTA: 'Book Assessment' (Lime)",
        "Secondary CTA: 'Shop Gear' (Outline)"
      ]
    },
    "services_section": {
      "title": "Concierge® Services",
      "type": "Horizontal Scroll / Bento Grid",
      "card_style": "Glassmorphic, tall aspect ratio",
      "interaction": "Hover expands card to show 'Book Now' button"
    },
    "products_section": {
      "title": "Shop for Fit",
      "type": "Clean Grid (5 columns)",
      "card_style": "Minimalist, white background, focus on product image",
      "features": ["Quick Add button", "Badges (New, Best Seller)"]
    },
    "programs_section": {
      "title": "Fitness Plans",
      "type": "Dashboard Grid",
      "card_style": "Data-dense, technical look",
      "features": ["Progress bars", "Week count", "Intensity level"]
    }
  },
  "assets": {
    "hero_images": [
      {
        "url": "https://images.unsplash.com/photo-1764377720157-b10acb5c32a9?crop=entropy&cs=srgb&fm=jpg&q=85",
        "alt": "Yellow Lab Agility Jump",
        "usage": "Hero Background or Cutout"
      },
      {
        "url": "https://images.unsplash.com/photo-1546815693-7533bae19894?crop=entropy&cs=srgb&fm=jpg&q=85",
        "alt": "Border Collie Running",
        "usage": "Alternative Hero"
      }
    ],
    "service_images": [
      {
        "url": "https://images.pexels.com/photos/5482887/pexels-photo-5482887.jpeg",
        "alt": "Dog Hydrotherapy",
        "service": "Hydrotherapy / Swimming"
      },
      {
        "url": "https://images.unsplash.com/photo-1546815693-7533bae19894?crop=entropy&cs=srgb&fm=jpg&q=85",
        "alt": "Dog Agility Tunnel",
        "service": "Agility Training"
      },
      {
        "url": "https://images.pexels.com/photos/8846092/pexels-photo-8846092.jpeg",
        "alt": "Dog Balance Training",
        "service": "Fitness Assessment"
      }
    ]
  },
  "components": {
    "buttons": {
      "primary": "bg-lime-500 text-emerald-950 hover:bg-lime-400 font-bold rounded-full px-8 py-4 transition-all hover:scale-105 shadow-lg shadow-lime-500/20",
      "secondary": "border-2 border-emerald-900/10 text-emerald-900 hover:bg-emerald-50 font-semibold rounded-full px-8 py-4"
    },
    "cards": {
      "service": "group relative overflow-hidden rounded-3xl bg-white border border-emerald-100 p-8 transition-all hover:shadow-2xl hover:-translate-y-1",
      "product": "group rounded-2xl bg-white p-4 transition-all hover:shadow-lg border border-transparent hover:border-emerald-100"
    },
    "badges": {
      "base": "inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ring-1 ring-inset",
      "success": "bg-emerald-50 text-emerald-700 ring-emerald-600/20",
      "warning": "bg-lime-50 text-lime-700 ring-lime-600/20"
    }
  },
  "instructions_to_main_agent": [
    "1. REWRITE FitPage.jsx completely. Do not keep the old structure.",
    "2. IMPLEMENT the 'Syne' and 'Manrope' fonts via Google Fonts import in the CSS.",
    "3. USE the provided image URLs for the respective sections.",
    "4. ENSURE the 'Concierge®' symbol is always present for services.",
    "5. CREATE a distinct visual separation between 'Services' (Bookable) and 'Products' (Buyable).",
    "6. INTEGRATE the 'MiraContextPanel' as a floating element or integrated sidebar.",
    "7. MAINTAIN the 'AdminQuickEdit' component functionality.",
    "8. USE 'sonner' for all toast notifications.",
    "9. ADD 'data-testid' to all interactive elements."
  ],
  "universal_guidelines": [
    "Avoid generic AI slop designs.",
    "Use 2-3x more spacing than typical.",
    "Micro-animations on every interaction.",
    "No center-aligned text for main content.",
    "Dark colors should be rich (tinted), not pure black."
  ]
}