{
  "design_system": {
    "identity": {
      "name": "The Doggy Company - Premium Dark",
      "tone": "Premium, Tech-forward, Emotional, Gamified",
      "archetype": "Luxury & Electric (Archetype 5/7 Hybrid)"
    },
    "colors": {
      "background": {
        "page": "bg-slate-950",
        "card": "bg-slate-900/60",
        "card_hover": "hover:bg-slate-800/60",
        "overlay": "bg-black/50"
      },
      "text": {
        "primary": "text-white",
        "secondary": "text-slate-400",
        "tertiary": "text-slate-500",
        "accent": "text-purple-400"
      },
      "borders": {
        "default": "border-white/10",
        "active": "border-purple-500/50"
      },
      "gradients": {
        "primary": "bg-gradient-to-r from-purple-600 to-pink-600",
        "soul": "bg-gradient-to-br from-violet-600 via-purple-600 to-fuchsia-600",
        "glass": "bg-gradient-to-b from-white/10 to-white/5"
      }
    },
    "typography": {
      "font_family": "Manrope, sans-serif",
      "headings": "font-bold tracking-tight text-white",
      "body": "text-slate-300 leading-relaxed"
    },
    "effects": {
      "glassmorphism": {
        "base": "backdrop-blur-xl bg-slate-900/60 border border-white/10 shadow-2xl",
        "heavy": "backdrop-blur-2xl bg-slate-950/80 border border-white/5",
        "light": "backdrop-blur-md bg-white/5 border border-white/10"
      },
      "shadows": {
        "glow": "shadow-[0_0_20px_rgba(168,85,247,0.2)]",
        "card": "shadow-xl shadow-black/20"
      },
      "animation": {
        "hover": "transition-all duration-300 ease-out hover:scale-[1.02]",
        "pulse_glow": "animate-pulse-slow"
      }
    },
    "layout": {
      "grid": "grid grid-cols-1 md:grid-cols-12 gap-6",
      "spacing": {
        "section": "py-8 md:py-12",
        "container": "px-4 md:px-8 lg:px-12"
      }
    }
  },
  "components": {
    "MemberDashboard": {
      "path": "/app/frontend/src/pages/MemberDashboard.jsx",
      "instructions": "Redesign the entire dashboard to match the premium dark theme. Replace all light mode classes with the defined dark mode system.",
      "changes": [
        {
          "selector": "main_container",
          "current": "bg-[#FAFAF9]",
          "new": "bg-slate-950 min-h-screen text-slate-200"
        },
        {
          "selector": "header_user_card",
          "current": "bg-white shadow-lg",
          "new": "bg-slate-900/50 backdrop-blur-xl border border-white/10 shadow-2xl shadow-purple-900/20"
        },
        {
          "selector": "tabs_list",
          "current": "bg-white/70 border-white/20",
          "new": "bg-slate-900/80 border-white/5 text-slate-400"
        },
        {
          "selector": "tab_trigger",
          "current": "data-[state=active]:bg-gradient... text-gray-600",
          "new": "data-[state=active]:bg-purple-600 data-[state=active]:text-white text-slate-400 hover:text-white hover:bg-white/5"
        },
        {
          "selector": "soul_score_card",
          "current": "bg-white/10 (on gradient)",
          "new": "bg-black/20 backdrop-blur-md border border-white/10 hover:bg-black/30"
        }
      ]
    },
    "GamificationBanner": {
      "path": "/app/frontend/src/components/dashboard/GamificationBanner.jsx",
      "instructions": "Update the banner to fit the dark theme. Ensure the 'white' parts are now semi-transparent dark glass.",
      "changes": [
        {
          "selector": "card_base",
          "current": "bg-white",
          "new": "bg-slate-900/60 backdrop-blur-xl border border-white/10"
        },
        {
          "selector": "progress_track",
          "current": "bg-white/20",
          "new": "bg-slate-800/50"
        },
        {
          "selector": "badge_card",
          "current": "bg-gray-50",
          "new": "bg-slate-800/50 border border-white/5"
        }
      ]
    },
    "PetSoulScore": {
      "path": "/app/frontend/src/components/PetSoulScore.jsx",
      "instructions": "Update SVG rings for dark mode contrast.",
      "changes": [
        {
          "selector": "background_circle",
          "current": "stroke='#E5E7EB' fill='white'",
          "new": "stroke='#334155' fill='transparent'"
        },
        {
          "selector": "text",
          "current": "text-gray-800",
          "new": "text-white"
        }
      ]
    }
  },
